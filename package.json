{
  "name": "skillevel",
  "version": "0.2.0",
  "description": "A test runner and authoring toolchain for Claude Code skills — vitest for skills. Scaffold, lint, and format SKILL.md files, then run YAML cases through `claude -p` to check that each skill triggers (and behaves) the way it should.",
  "type": "module",
  "bin": {
    "skillevel": "src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "smoke": "node src/cli.js --version && node src/cli.js __no_such_skill__",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "files": [
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "skills",
    "eval",
    "test-runner",
    "llm",
    "agent"
  ],
  "license": "MIT",
  "author": "junghwan16",
  "homepage": "https://github.com/junghwan16/skillevel#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/junghwan16/skillevel.git"
  },
  "bugs": {
    "url": "https://github.com/junghwan16/skillevel/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5"
  }
}
